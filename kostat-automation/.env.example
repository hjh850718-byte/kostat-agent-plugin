# ============================================================
# KOSTAT 자동화 환경변수 템플릿
# 이 파일을 복사하여 .env 로 저장 후 값을 채우세요.
# .env 파일은 절대 Git에 커밋하지 마세요.
# ============================================================

# Telegram Bot 설정
# @BotFather 에서 발급받은 토큰 (예: 1234567890:ABCDEFGabcdefg...)
TELEGRAM_BOT_TOKEN=여기에_봇_토큰_입력

# Telegram Chat ID (한준희 과장 개인 채팅 ID)
TELEGRAM_CHAT_ID=8761375155

# Claude 작업 디렉토리 (CLAUDE.md가 위치한 경로)
CLAUDE_WORK_DIR=C:\Users\USER\Documents\Claude\AGENT
