# ────────────────────────────────────────────────────────────────
# LLM 백엔드 선택
#   claude      → Anthropic API (기본값)
#   local       → LM Studio 로컬 서버 (오프라인·프라이버시 우선)
#   openrouter  → OpenRouter (무료 모델, 인터넷 필요)
# ────────────────────────────────────────────────────────────────
LLM_BACKEND=claude

# ── 디버그 ───────────────────────────────────────────────────────
# 1이면 요청·응답 요약, 소요 시간, 백엔드 선택 과정을 stderr에 출력
LLM_DEBUG=0
# 디버그 출력 시 프롬프트·응답 최대 표시 문자 수 (기본 200)
LLM_DEBUG_MAX_CHARS=200

# ── Claude (Anthropic) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# 사용할 모델 ID (기본값 claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# ── 로컬 LM Studio ───────────────────────────────────────────────
# 설정 순서:
#   1) LM Studio → Developer 탭 → 서버 켜기
#   2) 모델 로드 → K Cache=Q8_0 / V Cache=Q4_0 설정
#   3) Context Length = 100000~150000, GPU Offload 슬라이더 최대
#   4) 저장 후 아래 MODEL 값을 로드된 모델명으로 교체
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=gemma-4-26b-a4b
# LM Studio는 API 키를 검증하지 않으므로 임의 문자열 가능
LOCAL_LLM_API_KEY=lm-studio
# 콜드 스타트(JIT 최초 로딩) 30~60초 포함 — 120초 권장
LOCAL_LLM_TIMEOUT=120
# 최대 출력 토큰 (26B MoE 권장: 50000, 4B: 16000)
LOCAL_LLM_MAX_TOKENS=50000

# ── OpenRouter ───────────────────────────────────────────────────
# 비용 폭주 방지: 대시보드 → Limits → max credit=$1/월 + 허용 모델 목록 제한
# 신규 키 생성 시 max_credit=0으로 시작 권장
OPENROUTER_API_KEY=sk-or-...
# 무료 모델 예시 (변경 가능, :free 접미사 = 무료 티어)
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── KOSTAT 자동화 공통 ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
