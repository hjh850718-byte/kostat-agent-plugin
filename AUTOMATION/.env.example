# ────────────────────────────────────────────────
# LLM 백엔드 선택
#   claude      → Anthropic API (기본값)
#   local       → LM Studio 로컬 서버
#   openrouter  → OpenRouter (무료 모델 포함)
# ────────────────────────────────────────────────
LLM_BACKEND=claude

# ── Claude (Anthropic) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── 로컬 LM Studio ───────────────────────────────
# LM Studio Developer 탭에서 서버 기동 후 사용
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LM Studio에서 실제 로드된 모델 이름으로 교체
LOCAL_LLM_MODEL=gemma-4-26b-a4b
# LM Studio는 키 검증 안 함 — 임의 문자열 가능
LOCAL_LLM_API_KEY=lm-studio
# 콜드 스타트 30~60초 포함 여유값 (초)
LOCAL_LLM_TIMEOUT=120
# 최대 출력 토큰 (26B MoE 권장: 50000)
LOCAL_LLM_MAX_TOKENS=50000

# ── OpenRouter ───────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# 무료 모델 예시 (변경 가능)
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── KOSTAT 자동화 공통 ───────────────────────────
# Telegram 발송용
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
